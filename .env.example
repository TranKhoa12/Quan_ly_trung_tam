# ============================================================
# .env.example - Sao chép thành .env và điền giá trị thực
# ============================================================

# Môi trường: production | development
APP_ENV=production
APP_URL=https://yourdomain.com

# Database
DB_HOST=db
DB_NAME=quan_ly_trung_tam
DB_USER=app_user
DB_PASS=your_strong_password_here
DB_ROOT_PASS=your_root_password_here

# Cloudinary (nếu dùng upload ảnh)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================================
# AI Chat - Trợ lý hỏi đáp nội bộ
# Lấy API key miễn phí tại: https://aistudio.google.com
# ============================================================
# Provider: gemini | openai
AI_PROVIDER=gemini
# API Key của provider (bắt buộc để dùng tính năng Chat AI)
AI_API_KEY=AIzaSyDEO381xsJBp2jGzZXVcHvHZ2PWBfmkVDs 
# Model: gemini-1.5-flash (miễn phí) | gemini-1.5-pro | gpt-3.5-turbo | gpt-4o-mini
AI_MODEL=gemini-1.5-flash
