{
  "manifest_version": 3,
  "name": "Certificate Auto Fill",
  "version": "1.0.0",
  "description": "Tự động lấy dữ liệu từ form đăng ký học viên và điền vào form tạo chứng nhận",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://hocvien.tinhocsaoviet.com/*",
    "https://bt.banhmibebe.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://hocvien.tinhocsaoviet.com/register.php*",
        "http://hocvien.tinhocsaoviet.com/edit-profile-admin.php*",
        "https://hocvien.tinhocsaoviet.com/register.php*",
        "https://hocvien.tinhocsaoviet.com/edit-profile-admin.php*"
      ],
      "js": ["content/extract.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://bt.banhmibebe.com/Quan_ly_trung_tam/public/revenue*",
        "http://localhost/Quan_ly_trung_tam/public/certificates/create*",
        "http://localhost/Quan_ly_trung_tam/public/revenue*",
        "http://127.0.0.1/Quan_ly_trung_tam/public/revenue*"
      ],
      "js": ["content/fill.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
